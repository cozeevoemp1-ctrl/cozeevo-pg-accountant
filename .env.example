# =============================================================================
# Cozeevo PG Accountant — Environment Variables
# Copy to .env and fill in your values before starting the server.
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# ── Database (Supabase PostgreSQL) ────────────────────────────────────────────
# Get from: Supabase Dashboard → Project Settings → Database → Connection string
# Use the "asyncpg" (async) connection string, NOT the pooler URL.
DATABASE_URL=postgresql+asyncpg://postgres:[password]@db.[project-ref].supabase.co:5432/postgres

# Supabase REST API + Storage
SUPABASE_URL=https://[project-ref].supabase.co
SUPABASE_KEY=your-supabase-anon-key
SUPABASE_SERVICE_KEY=your-supabase-service-role-key   # Settings → API → service_role

# ── WhatsApp (Meta Cloud API) ─────────────────────────────────────────────────
# Get from: developers.facebook.com → your app → WhatsApp → API Setup
WHATSAPP_TOKEN=your-permanent-access-token
WHATSAPP_PHONE_NUMBER_ID=your-phone-number-id
WHATSAPP_APP_SECRET=your-meta-app-secret

# Webhook verify token — must match what you enter in Meta Developer Console
WHATSAPP_VERIFY_TOKEN=pg-accountant-verify

# ── WhatsApp Official Number (Reminders only) ────────────────
# Separate Business number for sending template-based reminders to tenants
# Both numbers can live under the same Meta Business Account (WABA)
REMINDER_WHATSAPP_TOKEN=your-official-number-token
REMINDER_WHATSAPP_PHONE_NUMBER_ID=your-official-phone-number-id

# Admin phone number (10-digit, receives lead visit notifications)
# your admin's WhatsApp number
ADMIN_PHONE=919000000000

# ── LLM Provider ─────────────────────────────────────────────────────────────
# Options: "ollama" (local) or "anthropic" (cloud)
# For VPS with limited RAM, consider "anthropic" to save memory.
LLM_PROVIDER=ollama

# Ollama (local LLM — only needed if LLM_PROVIDER=ollama)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# Anthropic (only needed if LLM_PROVIDER=anthropic)
# ANTHROPIC_API_KEY=sk-ant-your-key-here
# ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# ── App Settings ──────────────────────────────────────────────────────────────
# Generate a strong random secret: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=replace-with-a-random-secret-key-at-least-32-chars

ENVIRONMENT=production   # "development" or "production"
LOG_LEVEL=INFO

# ── File Storage ──────────────────────────────────────────────────────────────
DATA_RAW_DIR=./data/raw
DATA_PROCESSED_DIR=./data/processed
DATA_EXPORTS_DIR=./data/exports

# ── Supabase Auth (required for Owner PWA /api/v2/app/*) ─────────────────────
# SUPABASE_URL and SUPABASE_KEY already set above — add the JWT secret below.
# Get from: Supabase Dashboard → Project Settings → API → JWT Secret
SUPABASE_JWT_SECRET=<jwt-secret-from-project-settings-api>
# Custom SMS provider: Supabase sends OTP here; we forward it via WhatsApp (no Twilio needed).
# Generate any strong random string, set it here AND in Supabase Dashboard →
# Authentication → SMS Provider → Custom → "HTTP Bearer Token".
SUPABASE_SMS_HOOK_SECRET=<generate-with-openssl-rand-hex-32>
WHATSAPP_WABA_ID=your-waba-id

# UPI Auto-Reconciliation (Gmail poller)
GMAIL_USER=email-that-receives-bank-reports@gmail.com
GMAIL_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx
HULK_EMAIL_SUBJECT=HULK
THOR_EMAIL_SUBJECT=THOR
# your admin's WhatsApp number
ADMIN_WHATSAPP=919000000000

# ── Demo deployment ────────────────────────────────────────────────────────────
# Set DEMO_MODE=1 to run this codebase as a public demo against a fresh, empty
# database with zero of the real business's hardcoded data or outbound messaging:
#   - P&L Excel / occupancy dashboard skip all hardcoded verified/frozen months
#     (only live DB data is shown)
#   - All outbound WhatsApp sends (text/template/interactive/document) are
#     logged and no-op'd — nothing ever reaches Meta
#   - All Google Sheets writes/triggers are logged and no-op'd — demo has no sheet
#   - Monthly rollover still generates RentSchedule rows in DB, but skips the
#     Sheet tab creation/reconciliation steps
#   - The WhatsApp bot role allowlist uses DEMO_ROLES instead of the real
#     admin/owner/receptionist phone numbers
# Default is off — production behaviour is completely unchanged.
DEMO_MODE=0

# Fake total investment figure shown in demo Unit Economics (real default: ₹2.31Cr)
TOTAL_INVESTMENT=1000000

# DEMO_MODE bot role allowlist — "phone:name:role,phone2:name2:role2" (role: admin|owner|receptionist)
# If unset, falls back to a single admin at DEMO_ADMIN_PHONE.
DEMO_ROLES=
DEMO_ADMIN_PHONE=
