# ============================================================
# PG ACCOUNTANT — ENVIRONMENT CONFIGURATION TEMPLATE
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.
# ============================================================

# ── PG Owner Identity ────────────────────────────────────────
PG_OWNER_NAME="Your Name"
PG_BUSINESS_NAME="My PG House"
PG_PHONE_NUMBER="+91XXXXXXXXXX"
PG_ADDRESS="123 Main Street, City, State 000000"
PG_GST_NUMBER=""                          # optional

# ── Database ─────────────────────────────────────────────────
# SQLite (default, good for < 100k transactions)
DATABASE_URL="sqlite:///./data/pg_accountant.db"

# PostgreSQL (uncomment for production scale)
# DATABASE_URL="postgresql+asyncpg://user:password@localhost:5432/pg_accountant"

# ── LLM Provider ─────────────────────────────────────────────
# ollama=free local | groq=free cloud | anthropic=paid Claude
LLM_PROVIDER="ollama"

# ── Ollama (local, free) ──────────────────────────────────────
OLLAMA_URL="http://localhost:11434"
OLLAMA_MODEL="llama3.2"

# ── Groq (free cloud Llama) ───────────────────────────────────
GROQ_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
GROQ_MODEL="llama-3.1-8b-instant"

# ── Anthropic Claude (paid) ───────────────────────────────────
ANTHROPIC_API_KEY="sk-ant-XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
ANTHROPIC_MODEL="claude-haiku-4-5-20251001"
ANTHROPIC_MAX_TOKENS=512

# ── WhatsApp (Twilio) ────────────────────────────────────────
TWILIO_ACCOUNT_SID="ACXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
TWILIO_AUTH_TOKEN="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
TWILIO_WHATSAPP_FROM="whatsapp:+14155238886"
WHATSAPP_TO_NUMBER="whatsapp:+91XXXXXXXXXX"

# ── n8n Integration ──────────────────────────────────────────
N8N_BASE_URL="http://localhost:5678"
N8N_API_KEY="XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX"
N8N_WEBHOOK_SECRET="your-webhook-secret"

# ── n8n-mcp MCP Server (github.com/czlonkowski/n8n-mcp) ─────
# Used by Claude Code to access 1,084 n8n nodes + 2,700 templates.
# N8N_API_URL must point to your n8n instance (same as N8N_BASE_URL).
N8N_API_URL="http://localhost:5678"        # consumed by n8n-mcp
MCP_MODE="stdio"                           # required for Claude Code
DISABLE_CONSOLE_OUTPUT="true"             # suppress n8n-mcp console noise
WEBHOOK_SECURITY_MODE="moderate"          # local=lenient / cloud=strict
N8N_MCP_TELEMETRY_DISABLED="true"         # opt-out of n8n-mcp analytics

# ── n8n-skills (github.com/czlonkowski/n8n-skills) ──────────
# Install via Claude Code:  /plugin install czlonkowski/n8n-skills
# No env vars needed — skills are loaded from ~/.claude/skills/

# ── API Server ───────────────────────────────────────────────
API_HOST="0.0.0.0"
API_PORT=8000
API_SECRET_KEY="change-this-to-a-random-secret-string"
DEBUG=false

# ── Dashboard ────────────────────────────────────────────────
DASHBOARD_BASE_URL="http://localhost:8000"
DASHBOARD_TTL_HOURS=24                    # auto-delete after N hours
DASHBOARD_DIR="./dashboards"

# ── File Ingestion ───────────────────────────────────────────
DATA_RAW_DIR="./data/raw"
DATA_PROCESSED_DIR="./data/processed"
DATA_EXPORTS_DIR="./data/exports"

# ── Logging ──────────────────────────────────────────────────
LOG_LEVEL="INFO"
LOG_FILE="./data/pg_accountant.log"

# ── LangGraph ────────────────────────────────────────────────
LANGGRAPH_MAX_ITERATIONS=2
LANGGRAPH_TIMEOUT_SECONDS=30

# ── Rules Engine ─────────────────────────────────────────────
AI_FALLBACK_THRESHOLD=0.70               # confidence below this → AI classification
DEDUP_WINDOW_MINUTES=5                   # same amount + merchant within N min = duplicate
