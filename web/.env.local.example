NEXT_PUBLIC_SUPABASE_URL=https://<project>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-key>
NEXT_PUBLIC_API_URL=http://localhost:8000
GROQ_API_KEY=
OPENAI_API_KEY=

# Set to "1" on a public demo deployment to show the amber "DEMO" badge on the home header.
NEXT_PUBLIC_DEMO_MODE=0

# Comma-separated list of cash handler names shown in the Cash tab's "Paid by" / "Counted by"
# pickers. "Other" is always appended. Demo example: "Manager,Owner"
NEXT_PUBLIC_CASH_HANDLERS=Prabhakaran,Lakshmi
